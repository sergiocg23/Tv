# ============================================================
# Stack: tv — Variables de entorno
# Copiar a .env y ajustar los valores reales
# cp .env.example .env
# ============================================================

# -------------------------------------------
# JELLYFIN
# -------------------------------------------

# Credenciales admin
JELLYFIN_ADMIN_NAME=Admin
JELLYFIN_ADMIN_PASSWORD=AdminPass123

JELLYFIN_LOG_LEVEL=Information

# URL pública (para acceso remoto con Tailscale/VPN)
# JELLYFIN_PUBLISHED_URL=http://192.168.1.138:8096

# -------------------------------------------
# RED
# -------------------------------------------
# IP del host (cambiar según tu red)
HOST_IP=192.168.1.138

# -------------------------------------------
# IPTV LIST WATCHER
# -------------------------------------------
# URL de descarga de la lista IPTV
IPTV_LIST_URL=https://ipfs.io/ipns/k51qzi5uqu5di462t7j4vu4akwfhvtjhy88qbupktvoacqfqe9uforjvhyi4wr/data/listas/lista_iptv.m3u

# Directorio de salida para las listas descargadas (dentro del contenedor)
IPTV_OUTPUT_DIR=/app/playlist/ListWatcher

# Nombre del archivo de salida
IPTV_FILENAME=iptvWatcher.m3u

# IP genérica que se reemplazará en las listas
IPTV_GENERIC_IP=127.0.0.1

# Timeout para descargas en segundos
IPTV_DOWNLOAD_TIMEOUT=30

# -------------------------------------------
# IPTV LIST VALIDATOR
# -------------------------------------------
# Directorio de salida para archivos validados
VALIDATOR_OUTPUT_DIR=/app/playlist/ListValidator

# Timeout de conexión en segundos (para validar enlaces)
# Acestream necesita tiempo para conectar P2P, encontrar peers y buffering inicial
# 60-90s es razonable para streams que pueden tardar en iniciar
VALIDATOR_TIMEOUT_CONNECT=90

# Timeout de stream en segundos (para validar streaming)
VALIDATOR_TIMEOUT_STREAM=120

# Duración del test de estabilidad en segundos
VALIDATOR_STABILITY_TEST_DURATION=15

# Bitrate mínimo esperado en bytes/segundo (300KB/s por defecto)
# Reducido para aceptar streams de menor calidad
VALIDATOR_MIN_BITRATE=300000

# Método de análisis de streams
# - basic: Validación HTTP rápida (sin dependencias, ~5-10s por stream)
# - ffprobe: Solo análisis de metadatos rápido (~2-5s por stream, requiere ffprobe)
# - ffmpeg: Solo análisis completo descargando video (~10-30s por stream, requiere ffmpeg)
# - auto: Intenta ffprobe primero → si falla intenta ffmpeg → si no están disponibles usa basic (recomendado)
VALIDATOR_ANALYSIS_METHOD=auto

# Duración del análisis con ffmpeg en segundos
# Cuanto más tiempo, más preciso pero más lento
VALIDATOR_FFMPEG_DURATION=10

# Timeout para ffmpeg/ffprobe en segundos
VALIDATOR_FFMPEG_TIMEOUT=30

# Análisis híbrido: Combina test básico + análisis avanzado
# true: Primero test de conectividad rápido (5-10s) → si PASA → análisis ffmpeg completo
#       Ventaja: Descarta rápido streams inválidos sin gastar tiempo en análisis avanzado
#       Tiempo: ~15-40s por stream válido, ~5-10s por stream inválido
# false: Solo análisis con el método seleccionado (sin pre-filtrado)
#        Tiempo: Depende del método (basic: 5-10s, ffprobe: 2-5s, ffmpeg: 10-30s)
VALIDATOR_HYBRID_ANALYSIS=true

# Número máximo de reintentos para HTTP 500 o Timeout
# Acestream puede tardar en iniciar streams P2P (búsqueda de peers, buffering)
# Se recomienda 3-5 reintentos con delay de 5s
VALIDATOR_MAX_RETRIES=3

# Delay en segundos entre reintentos
VALIDATOR_RETRY_DELAY=5

# Archivo JSON para sistema de confianza
# Almacena scores de confianza, estadísticas y métricas de calidad por stream
VALIDATOR_CONFIDENCE_FILE=confidence.json