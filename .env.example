# ===========================================
# Configuración de variables de entorno
# ===========================================
# 
# Copia este archivo a .env y ajusta los valores
# cp .env.example .env

# -------------------------------------------
# JELLYFIN
# -------------------------------------------

# Credenciales admin
JELLYFIN_ADMIN_NAME=Admin
JELLYFIN_ADMIN_PASSWORD=AdminPass123

JELLYFIN_LOG_LEVEL=Information

# URL pública (para acceso remoto con Tailscale/VPN)
# JELLYFIN_PUBLISHED_URL=http://192.168.1.138:8096

# -------------------------------------------
# RED
# -------------------------------------------
# IP del host (cambiar según tu red)
HOST_IP=192.168.1.138