# ===========================================
# Configuración de variables de entorno
# ===========================================
# 
# Copia este archivo a .env y ajusta los valores
# cp .env.example .env

# -------------------------------------------
# JELLYFIN
# -------------------------------------------

# Credenciales admin
JELLYFIN_ADMIN_NAME=Admin
JELLYFIN_ADMIN_PASSWORD=AdminPass123

JELLYFIN_LOG_LEVEL=Information

# URL pública (para acceso remoto con Tailscale/VPN)
# JELLYFIN_PUBLISHED_URL=http://192.168.1.138:8096

# -------------------------------------------
# RED
# -------------------------------------------
# IP del host (cambiar según tu red)
HOST_IP=192.168.1.138

# -------------------------------------------
# IPTV LIST WATCHER
# -------------------------------------------
# URL de descarga de la lista IPTV
IPTV_LIST_URL=https://ipfs.io/ipns/k2k4r8oqlcjxsritt5mczkcn4mmvcmymbqw7113fz2flkrerfwfps004/data/listas/lista_iptv.m3u

# Directorio de salida para las listas descargadas (dentro del contenedor)
IPTV_OUTPUT_DIR=/app/playlist/ListWatcher

# Nombre del archivo de salida
IPTV_FILENAME=iptvWatcher.m3u

# IP genérica que se reemplazará en las listas
IPTV_GENERIC_IP=127.0.0.1

# Timeout para descargas en segundos
IPTV_DOWNLOAD_TIMEOUT=30

# -------------------------------------------
# IPTV LIST VALIDATOR
# -------------------------------------------
# Directorio de salida para archivos validados
VALIDATOR_OUTPUT_DIR=/app/playlist/ListValidator

# Timeout de conexión en segundos (para validar enlaces)
# Acestream necesita tiempo para conectar P2P, encontrar peers y buffering inicial
# 60-90s es razonable para streams que pueden tardar en iniciar
VALIDATOR_TIMEOUT_CONNECT=90

# Timeout de stream en segundos (para validar streaming)
VALIDATOR_TIMEOUT_STREAM=120

# Duración del test de estabilidad en segundos
VALIDATOR_STABILITY_TEST_DURATION=15

# Bitrate mínimo esperado en bytes/segundo (300KB/s por defecto)
# Reducido para aceptar streams de menor calidad
VALIDATOR_MIN_BITRATE=300000