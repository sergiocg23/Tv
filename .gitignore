# ============================================================
# Stack: tv — .gitignore
# ============================================================

# --- Data runtime (NO versionable) ---
data/
!data/.gitkeep
!data/**/.gitkeep

# --- Jellyfin legacy (pendiente de migrar a data/) ---
jellyfin/
!config/jellyfin/

# --- Playlist legacy (pendiente de migrar a data/) ---
playlist/

# --- Logs legacy (pendiente de migrar a data/) ---
logs/

# --- Environment ---
.env
!.env.example

# --- SSL ---
*.pem

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Logs ---
*.log

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/

# --- OS ---
Thumbs.db
.Spotlight-V100
.Trashes

# --- Temporary ---
*.tmp
*.bak
*.backup

*.github/